# Django secret key
SECRET_KEY=your-secret-key-here

# True in dev, False in prod
DEBUG=True

# Comma-separated list
ALLOWED_HOSTS=localhost,127.0.0.1

# e.g. http://localhost:3000 (comma-separated if multiple)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Set to "true" to use hardcoded mock detections (no model needed)
# Set to "false" to run the real DeepFashion2 model
USE_MOCK_DETECTOR=false
